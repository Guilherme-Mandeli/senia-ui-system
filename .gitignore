# ==========================================================================
# Senia UI CSS Framework - Git Ignore Rules
# ==========================================================================

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Build and distribution directories
dist/
dist-ssr/
out/
build/
.vite-temp/
vite.config.js.timestamp-*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (next.js / vite)
.pnp/*
.pnp.js

# Local environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# Editor and IDE directories
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Testing and coverage
coverage/
.nyc_output/

# Temporary storage & cache
.sass-cache/
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
